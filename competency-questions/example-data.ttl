# --- Countermeasure Executions ------------------------------------------------

ex:CE_001 a mqto:CountermeasureExecution ;
    lis:implements ex:AdjustMeltTemp ;
    mqto:mitigated ex:FO_001 ;
    mqto:suggestedBy ex:FO_001 ;
    mqto:startTime "2026-03-15T10:30:00"^^xsd:dateTime ;
    mqto:endTime "2026-03-15T11:20:00"^^xsd:dateTime ;
    mqto:score 0.92 ;
    pko:includesStepExecution ex:CSE_001 , ex:CSE_002 , ex:CSE_003 .

ex:CE_002 a mqto:CountermeasureExecution ;
    lis:implements ex:VerifyThermocouple ;
    mqto:suggestedBy ex:FO_003 ;
    mqto:startTime "2026-03-17T11:30:00"^^xsd:dateTime ;
    mqto:abortedTime "2026-03-17T12:00:00"^^xsd:dateTime ;
    mqto:abortedReason "Thermocouple within calibration limits; no adjustment needed." ;
    mqto:score 0.75 ;
    pko:includesStepExecution ex:CSE_006 , ex:CSE_004 , ex:CSE_005 .

# --- Countermeasure Step Executions -------------------------------------------

ex:CSE_001 a mqto:CountermeasureStepExecution ;
    lis:implements ex:CheckCurrentTemp ;
    mqto:completionTime "2026-03-15T10:35:00"^^xsd:dateTime ;
    pko:nextStepExecution ex:CSE_002 .

ex:CSE_002 a mqto:CountermeasureStepExecution ;
    lis:implements ex:AdjustFurnaceSetpoint ;
    mqto:completionTime "2026-03-15T10:50:00"^^xsd:dateTime ;
    pko:previousStepExecution ex:CSE_001 ;
    pko:nextStepExecution ex:CSE_003 .

ex:CSE_003 a mqto:CountermeasureStepExecution ;
    lis:implements ex:VerifyNewTemp ;
    mqto:completionTime "2026-03-15T11:20:00"^^xsd:dateTime ;
    pko:previousStepExecution ex:CSE_002 .

# CSE_006 implements CheckCurrentTemp — the same step specification that
# CSE_001 (in CE_001) also implements. This demonstrates step reuse across
# different countermeasure executions.
ex:CSE_006 a mqto:CountermeasureStepExecution ;
    lis:implements ex:CheckCurrentTemp ;
    mqto:completionTime "2026-03-17T11:35:00"^^xsd:dateTime ;
    pko:nextStepExecution ex:CSE_004 .

ex:CSE_004 a mqto:CountermeasureStepExecution ;
    lis:implements ex:InspectThermocouple ;
    mqto:completionTime "2026-03-17T11:45:00"^^xsd:dateTime ;
    pko:previousStepExecution ex:CSE_006 ;
    pko:nextStepExecution ex:CSE_005 .

ex:CSE_005 a mqto:CountermeasureStepExecution ;
    lis:implements ex:CalibrateIfNeeded ;
    mqto:abortedTime "2026-03-17T12:00:00"^^xsd:dateTime ;
    mqto:abortedReason "Not needed — thermocouple readings within tolerance." ;
    pko:previousStepExecution ex:CSE_004 .

