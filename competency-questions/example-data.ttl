    lis:implements ex:ColdShut ;
    mqto:appearedOn ex:Machine4115 ;
    mqto:occurrenceTime "2026-03-20T09:30:00"^^xsd:dateTime .

# Failure appeared on PhysicalMaterial (not Machine) — raised by material metric
ex:FO_005 a mqto:FailureOccurrence ;
    lis:implements ex:AlloyContamination ;
    mqto:appearedOn ex:AlBatch2026_0043 ;
    mqto:raisedBy ex:MA_007 ;
