# CQ-13: Was a detected failure or a suggested countermeasure rejected by the user?
#
# This query identifies failures and countermeasures that were rejected, indicating
# false positives or inapplicable suggestions.

PREFIX mqto: <https://w3id.org/mqto#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX lis: <http://rds.posccaesar.org/ontology/lis14/rdl/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?item ?itemType ?itemLabel ?rejectedValue ?viewTime ?note
WHERE {
  {
    # Rejected failure occurrences
    ?item a mqto:FailureOccurrence ;
          mqto:rejected ?rejectedValue ;
          mqto:viewTime ?viewTime .

    BIND("FailureOccurrence" AS ?itemType)

    OPTIONAL {
      ?item lis:implements ?failureSpec .
      ?failureSpec rdfs:label ?itemLabel .
    }

    OPTIONAL {
      ?item mqto:note ?note .
    }
  }
  UNION
  {
    # Rejected countermeasure executions
    ?item a mqto:CountermeasureExecution ;
          mqto:rejected ?rejectedValue ;
          mqto:startTime ?viewTime .

    BIND("CountermeasureExecution" AS ?itemType)

    OPTIONAL {
      ?item lis:implements ?cmSpec .
      ?cmSpec rdfs:label ?itemLabel .
    }

    OPTIONAL {
      ?item mqto:note ?note .
    }
  }

  # Only show rejected items
  FILTER(?rejectedValue = true)
}
ORDER BY DESC(?viewTime)
